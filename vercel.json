{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        },
        {
            "src": "server/src/index.ts",
            "use": "@vercel/node"
        }
    ],
    "rewrites": [
        {
            "source": "/sitemap.xml",
            "destination": "server/src/index.ts"
        },
        {
            "source": "/robots.txt",
            "destination": "/robots.txt"
        },
        {
            "source": "/google(.*).html",
            "destination": "/google$1.html"
        },
        {
            "source": "/invitacion/(.*)",
            "destination": "server/src/index.ts"
        },
        {
            "source": "/api/(.*)",
            "destination": "server/src/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/check-late-orders",
            "schedule": "0 0 * * *"
        },
        {
            "path": "/api/cron/check-birthdays",
            "schedule": "0 9 * * *"
        },
        {
            "path": "/api/cron/generate-daily-report",
            "schedule": "5 0 * * *"
        },
        {
            "path": "/api/cron/cleanup-deleted-users",
            "schedule": "0 3 * * *"
        },
        {
            "path": "/api/cron/check-abandoned-carts",
            "schedule": "0 18 * * *"
        }
    ],
    "images": {
        "sizes": [256, 384, 400, 640, 750, 800, 828, 1080, 1200, 1920, 2048, 3840],
        "domains": ["images.unsplash.com"],
        "minimumCacheTTL": 60,
        "formats": ["image/avif", "image/webp"],
        "remotePatterns": [
            {
                "protocol": "https",
                "hostname": "*.supabase.co"
            },
            {
                "protocol": "https",
                "hostname": "dvsmzciknlfevgxpnefr.supabase.co"
            },
            {
                "protocol": "https",
                "hostname": "images.unsplash.com"
            }
        ]
    }
}
